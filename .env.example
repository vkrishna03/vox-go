# Speech-to-text provider
STT_PROVIDER=deepgram  # currently supported: deepgram
STT_API_KEY=your_key_here
STT_MODEL=nova-3  # see https://developers.deepgram.com/docs/models

# Text-to-speech provider
TTS_PROVIDER=deepgram  # currently supported: deepgram
TTS_API_KEY=            # optional, defaults to STT_API_KEY if using same Deepgram account
TTS_MODEL=aura-asteria-en  # see https://developers.deepgram.com/docs/tts-models

# LLM provider (any OpenAI-compatible API)
LLM_API_KEY=your_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1  # Groq (default)
# LLM_BASE_URL=https://api.openai.com/v1      # OpenAI
# LLM_BASE_URL=http://localhost:11434/v1       # Ollama
LLM_MODEL=llama-3.3-70b-versatile

# Voice activity detection sensitivity (0.0-1.0, lower = more sensitive)
VAD_THRESHOLD=0.3
VAD_THRESHOLD_BUMP=0.7  # higher threshold used during TTS playback to avoid echo

# Logging (empty = disabled, "debug", "info", "warn", "error")
# LOG_LEVEL=debug
