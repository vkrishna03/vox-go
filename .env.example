# Speech-to-text provider
STT_PROVIDER=deepgram  # currently supported: deepgram
STT_API_KEY=your_key_here

# LLM provider (any OpenAI-compatible API)
LLM_API_KEY=your_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1  # Groq (default)
# LLM_BASE_URL=https://api.openai.com/v1      # OpenAI
# LLM_BASE_URL=http://localhost:11434/v1       # Ollama
LLM_MODEL=llama-3.3-70b-versatile

# Voice activity detection sensitivity (0.0-1.0, lower = more sensitive)
VAD_THRESHOLD=0.3
